  "rollout_plan_displayname": "Will ship enabled for all users",
  "motivation": "Authors would like to customize the highlighted text from find-in-page to have a style consistent with that of the rest of the page. In particular, the existing find-in-page highlights may offer poor contrast, harming accessibility.",
  "devtrial_instructions": "https://github.com/Igalia/explainers/blob/main/css/find-in-page/README.md",
  "activation_risks": "There is no way to polyfill this. There is no real challenge to adopting beyond awareness that the feature exists, and we will be producing blog postings and other social media evangelization.",
  "measurement": "We will implement UseCounters for this pseudo element (and all the other too, see https://issues.chromium.org/issues/381093928)",
  "availability_expectation": "Available in Chrome, and Firefox.\nNot available in Safari",
  "adoption_expectation": "Hard to predict and not relevant to most sites",
  "adoption_plan": "Blog posts and developer outreach",
  "initial_public_proposal_url": "https://github.com/w3c/csswg-drafts/issues/3812",
  "explainer_links": [
    "https://github.com/Igalia/explainers/blob/main/css/find-in-page/README.md"
  ],
  "requires_embedder_support": false,
  "spec_link": "https://drafts.csswg.org/css-pseudo-4/#selectordef-search-text",
  "api_spec": false,
  "automation_spec": false,
  "interop_compat_risks": "The feature is in the CSS Pseudo spec and there are no open issues. The behavior is designed to be implementable in Firefox and Chrome, but is unlikely to be viable in Safari due to highly customize UI for find-in-page. The spec is explicit that browsers may choose not to implement this feature provided @supports information is correct. The Safari behavior is so different that developers are unlikely to believe their styling would apply there.",
  "all_platforms": true,
  "all_platforms_descr": "All platforms support find-in-page and could use CSS styling to improve legibility on some sites.",
  "non_oss_deps": "No",
  "anticipated_spec_changes": "None",
  "security_risks": "There is no security risk. The CSS styling is available regardless of whether the text is search for or not, so user find-in-page queries cannot be seen by script.",
  "ergonomics_risks": "None.",
  "wpt": false,
  "wpt_descr": "Testing is in wpt_internal tests due to a lack of wpt support for adding find-in-page markers.\n\nthird_party/blink/web_tests/wpt_internal/css/css-pseudo/search-text-*",
  "webview_risks": "No",
