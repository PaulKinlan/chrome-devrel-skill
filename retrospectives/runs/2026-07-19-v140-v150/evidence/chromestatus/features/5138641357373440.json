  "rollout_plan_displayname": "Will ship enabled for all users",
  "motivation": "Many sites want to perform some work during document unloading. This usually includes writing to storage, or sending information to severs.\n\nCurrently, if this work is done asynchronously (e.g., writing to IndexedDB instead of localStorage, or using CompressionStream to compress the body before sending a fetch()) the only way to do this is to use a service worker. However, requiring a service worker for this simple case of work-after-unload is heavyweight: the disk space, memory consumption, and developer experience of managing the service worker registration and lifecycle makes this hard to deploy. By using shared workers, all of these downsides are avoided.",
  "devtrial_instructions": null,
  "activation_risks": null,
  "measurement": null,
  "availability_expectation": null,
  "adoption_expectation": null,
  "adoption_plan": null,
  "initial_public_proposal_url": "https://github.com/whatwg/html/issues/10997",
  "explainer_links": [
    "https://gist.github.com/domenic/c5bd38339f33b49120ae11b3b4af5b9b#file-1-explainer-md"
  ],
  "requires_embedder_support": false,
  "spec_link": "https://github.com/whatwg/html/commit/9c009049e4fa9dba638ef68ca502b781082bbb68",
  "api_spec": true,
  "automation_spec": false,
  "interop_compat_risks": "We intend to specify that the lifetime timeout for these shared workers be extended in the same way as service workers. Because the exact timeout of service workers is left implementation-defined, it's possible that code using this new feature could be non-interoperable. However, this has so far not proved to be a major problem in practice for service workers.",
  "all_platforms": null,
  "all_platforms_descr": "Shared workers are not yet supported on Android and Android WebView. However, we are concurrently working on enabling them there, and when we do, this feature will also be supported.",
  "non_oss_deps": null,
  "anticipated_spec_changes": "We are currently discussing some details in preparation for specification. The exact nature of how the lifetime extension works with regard to non-window clients, particularly, has only recently reached a tentative conclusion.",
  "security_risks": null,
  "ergonomics_risks": null,
  "wpt": true,
