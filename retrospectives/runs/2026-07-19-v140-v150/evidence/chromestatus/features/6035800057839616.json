  "new_crbug_url": "https://bugs.chromium.org/p/chromium/issues/entry?components=Blink>DOM&blocking=486928684&cc=ansollan@microsoft.com,leo.lee@microsoft.com,daniec@microsoft.com,aluhrs@microsoft.com",
