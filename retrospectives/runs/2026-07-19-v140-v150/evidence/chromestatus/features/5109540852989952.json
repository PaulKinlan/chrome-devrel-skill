{
  "id": 5109540852989952,
  "name": "Gamepad ongamepadconnected and ongamepaddisconnected event handler attributes",
  "summary": "Add ongamepadconnected and ongamepaddisconnected event handlers to the WindowEventHandlers interface mixin.\r\n\r\nThis would enable support for window.ongamepad[dis]connected or document.body.ongamepad[dis]connected event handler attributes.",
