{
  "id": 5637601087193088,
  "name": "Focusgroup",
  "summary": "Gives authors the ability to declaratively give composite widgets arrow key navigation, a guaranteed tab stop, and last-focused memory, replacing hand-coded roving tabindex scripts.\nExample:\n<div focusgroup=\"toolbar wrap\" aria-label=\"Formatting\">\n  <button>Bold</button>\n  <button>Italic</button>\n  <button>Underline</button>\n</div>",
