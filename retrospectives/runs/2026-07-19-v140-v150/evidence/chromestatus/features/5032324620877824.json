  "rollout_plan_displayname": "Will ship enabled for all users",
  "motivation": "To protect themselves from code injection, developers can restrict themselves to loading script from certain URLs and certain `<script>` elements (through Content Security Policy), and to loading script whose content is well-known (through Subresource Integrity). These satisfy a large number of use case, but fail to satisfy others (particularly supply chain integrity for dynamic resources). Signatures reasonably address this hole, nicely complementing the existing mechanisms.",
  "devtrial_instructions": null,
  "activation_risks": "None.",
  "measurement": null,
  "availability_expectation": null,
  "adoption_expectation": null,
  "adoption_plan": null,
  "initial_public_proposal_url": "https://github.com/w3c/webappsec/issues/449",
  "explainer_links": [
    "https://github.com/WICG/signature-based-sri"
  ],
  "requires_embedder_support": false,
  "spec_link": "https://wicg.github.io/signature-based-sri",
  "api_spec": false,
  "automation_spec": false,
  "interop_compat_risks": null,
  "all_platforms": true,
  "all_platforms_descr": null,
  "non_oss_deps": null,
  "anticipated_spec_changes": null,
  "security_risks": "The feature aims to plug a security hole in the platform's status quo ante: it is impossible to deploy content-based integrity checks for dynamic resources, and URL-based checks are too broad to provide meaningful security protections.\n\nWe continue to require CORS-based opt-in for integrity checks on responses to ensure that we're not leaking data unintentionally between origins.",
  "ergonomics_risks": "The hash functions we currently support for SRI generally are not conducive to streaming responses. This is arguably fine for scripts and stylesheets (as those are executed atomically, requiring the entire body), but it cannot work for other resource types (images, video, etc). It's likely we'll want to extend the set of hash functions in the future (though we'd do that for SRI, CSP, and this mechanism in one fell swoop).",
  "wpt": true,
  "wpt_descr": "https://wpt.fyi/results/subresource-integrity/unencoded-digest?label=experimental&label=master&aligned\nhttps://wpt.fyi/results/subresource-integrity/signatures?label=experimental&label=master&aligned",
  "webview_risks": null,
  "devrel_emails": [
    "devrel-chromestatus-all@google.com"
  ],
  "debuggability": "`Signature` and `Signature-Input` header parsing and validation is well-covered with DevTools issues. The same is true for `Unencoded-Digest` parsing and enforcement.",
