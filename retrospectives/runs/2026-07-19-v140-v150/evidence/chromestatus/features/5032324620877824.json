    {
      "id": 6571997449158656,
      "created": "2024-12-06 13:35:42.861064",
      "feature_id": 5032324620877824,
      "stage_type": 150,
      "display_name": "Signature-based SRI",
      "intent_stage": 3,
      "pm_emails": [],
      "tl_emails": [],
