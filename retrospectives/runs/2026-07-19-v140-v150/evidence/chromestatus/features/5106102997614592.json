{
  "id": 5106102997614592,
  "name": "Secure Payment Confirmation: Browser Bound Keys",
  "summary": "Adds an additional cryptographic signature over Secure Payment Confirmation assertions and credential creation. The corresponding private key is not synced across devices. This helps web developers meet requirements for device binding for payment transactions.",
