  "activation_risks": null,
  "measurement": "A new GetSecurePaymentConfirmationCapabilities UseCounter will be created and used.",
  "availability_expectation": "The GetSecurePaymentConfirmationCapabilities method will only be available in Chromium browsers for the foreseeable future.",
