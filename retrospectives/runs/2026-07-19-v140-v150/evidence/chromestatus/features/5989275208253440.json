      "intent_thread_url": "https://groups.google.com/a/chromium.org/d/msgid/blink-dev/CH4PR00MB23897DFC0C754FDDCC5DFBFBD5372%40CH4PR00MB2389.namprd00.prod.outlook.com",
      "announcement_url": null,
      "experiment_goals": "The OT should help us collect information on the performance impact of this change across real users. There is a high chance that the current API shape is NOT its final form (see more at https://github.com/w3c/gamepad/issues/4). We want to measure whether this version of raw events brings measurable performance improvements for cloud gaming, considering many different devices. If it negatively impacts low-powered devices, we'll need to work with partners on improvements. It could be adding event coalescing, changing the spec proposal to permit event throttling, etc.",
      "experiment_risks": "If the origin trials finish before the feature is enabled by default, websites need to be able to fall back to the previous polling mechanism. Otherwise, they will not be able to get gamepad input data. To do that, the web application must detect that the GamepadRawInputChangeEvent is available prior to using it. This can be done by doing the check \"'GamepadRawInputChangeEvent' in window\".",
      "origin_trial_id": "3118179792000647169",
      "origin_trial_feedback_url": null,
      "ot_action_requested": false,
      "ot_approval_buganizer_component": null,
