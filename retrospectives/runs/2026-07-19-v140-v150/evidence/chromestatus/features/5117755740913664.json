  "new_crbug_url": "https://bugs.chromium.org/p/chromium/issues/entry?components=Blink>Agentic Platform>WebMCP&blocking=445637567&cc=khushalsagar@chromium.org,skmanickam@chromium.org,bengr@chromium.org,masonf@chromium.org,dom@chromium.org,mfoltz@chromium.org",
  "screenshot_links": [],
  "first_enterprise_notification_milestone": null,
  "enterprise_impact": 1,
  "breaking_change": false,
  "confidential": false,
  "shipping_year": 2026,
  "flag_name": "Experimental Web Platform features",
  "finch_name": "WebMCP",
  "non_finch_justification": null,
  "ongoing_constraints": "No technical constraints for the experiments. ",
  "rollout_plan": 0,
  "rollout_plan_displayname": "Will ship enabled for all users",
  "motivation": "The web platform's ubiquity and popularity have made it the world's gateway to information and capabilities. Its ability to support complex, interactive applications beyond static content, has empowered developers to build rich user experiences and applications. As AI agents become more prevalent, the potential for even greater user value is within reach.\n\nFor the Web to succeed, it needs to APIs to interact with Agents beyond UIs written for humans.",
  "devtrial_instructions": "https://docs.google.com/document/d/1rtU1fRPS0bMqd9abMG_hc6K9OAI6soUy3Kh00toAgyk/edit?tab=t.0",
  "activation_risks": "There are no activation requirements to register WebMCP tools.  To execute WebMCP tools does require an agent, either provided by the browser or site author, to formulate and orchestrate tool calls.  There are several Chrome extensions already available that allow cloud-LLM-based agents to discover and call WebMCP tools. It is also possible to use the Prompt API to call WebMCP tools using on-device models.",
  "measurement": null,
  "availability_expectation": null,
  "adoption_expectation": null,
  "adoption_plan": null,
  "initial_public_proposal_url": "https://github.com/explainers-by-googlers/script-tools",
  "explainer_links": [
    "https://github.com/webmachinelearning/webmcp"
  ],
  "requires_embedder_support": true,
  "spec_link": "https://webmachinelearning.github.io/webmcp",
  "api_spec": true,
  "automation_spec": false,
  "interop_compat_risks": "Given this is a new space and new API - there's no compatibility risk.\n\nUsual risk related to other browser vendors not adopting the API apply. This API is meant to augment capabilities provided by browser add-ons and so non-adoption in other engines would have limited user-impact and thus we consider the risk to be low.",
  "all_platforms": true,
  "all_platforms_descr": null,
  "non_oss_deps": null,
  "anticipated_spec_changes": null,
  "security_risks": "Sites may consume and expose sensitive information when their WebMCP tools are called by agents.  Agents should implement safeguards to ensure that sensitive information is passed to sites and between origins only under the consent of the user that is supervising them.\n\nLLM-based agents are susceptible to attacks such as indirect prompt injection, which can cause an exploited agent to exfiltrate sensitive information in its context to an attacker.  Agents should implement safeguards against prompt injection and related attacks. ",
  "ergonomics_risks": "There is a risk that site authors that wish to incorporate WebMCP tools into their sites will need to duplicate functionality that currently exists to drive the user interface.  We're hoping that most imperative WebMCP tools are just thin wrappers around existing code that drives actions on the site, but we are working with framework developers like React to ensure that WebMCP tools can be added without rearchitecting the site logic.  We are also offering a declarative version that requires only adding attributes to existing form elements, which is much lighter weight to deploy and does not require any refactoring of existing site functionality. ",
  "wpt": null,
  "wpt_descr": "The IDL and basic usage is tested via WPTs.\n\nSince the API provides the user agent with the ability to call certain tools, we might need to extend the WPT harness to support this.",
  "webview_risks": null,
  "devrel_emails": [
    "devrel-chromestatus-all@google.com"
  ],
  "debuggability": "Explicit debugging support through a new WebMCP Chrome DevTools Protocol domain. The domain supports listing registered tools, invoking tools, and logging all calls by agents. Registration issues for declarative tools (e.g., missing names or descriptions) are reported through the Audits domain.",
