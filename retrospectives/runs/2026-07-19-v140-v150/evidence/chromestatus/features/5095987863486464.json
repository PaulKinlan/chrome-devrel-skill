{
  "id": 5095987863486464,
  "name": "Deprecate and remove: non-allowlisted Event interfaces from document.createEvent()",
  "summary": "Remove support for creating non-allowlisted event interfaces from document.createEvent().\nAfter this change, these will throw NOT_SUPPORTED_ERR as required by the specification.\n(However, events with usage above 0.01% or those deemed difficult to remove immediately will either be deprecated only)",
