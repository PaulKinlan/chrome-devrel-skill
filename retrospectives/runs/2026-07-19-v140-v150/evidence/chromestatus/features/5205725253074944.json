    {
      "id": 6226523283652608,
      "created": "2025-09-05 23:47:01.463242",
      "feature_id": 5205725253074944,
      "stage_type": 150,
      "display_name": "Email Verification Protocol",
      "intent_stage": 3,
      "pm_emails": [],
      "tl_emails": [],
