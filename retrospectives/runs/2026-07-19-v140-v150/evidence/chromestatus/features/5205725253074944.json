      "view": {
        "url": "https://github.com/WebKit/standards-positions/issues/578",
        "notes": "We haven't formally gotten a review from Webkit, but we got some informal feedback last TPAC with their preference to augment WebOTP / one-time-codes and OTPs. We believe this alternative isn't necessarily mutually exclusive and can work symbiotically with what's being proposed. We expanded on that here: \n\nhttps://github.com/samuelgoto/email-verification-protocol#webotp-otps-vs-evts-and-imap",
        "text": "No signal",
        "val": 5
      }
