{
  "id": 5153932394102784,
  "name": "named-feature() function for CSS @supports",
  "summary": "The named-feature() function allows CSS @supports rules to query for a small set of specific named features that are not possible to test for using other @supports mechanisms but which are considered highly valuable to test for.",
