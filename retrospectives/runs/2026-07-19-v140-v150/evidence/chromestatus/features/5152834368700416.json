  "new_crbug_url": "https://bugs.chromium.org/p/chromium/issues/entry?components=Blink>AppManifest&blocking=454827186&cc=liahiscock@microsoft.com,kristinlee@microsoft.com,limzh@microsoft.com",
  "screenshot_links": [],
