  "activation_risks": null,
  "measurement": "Separate programmatic counters for the .idl methods and attributes (via MeasureAs) are included to track the stats for API usage:\n\nSubAppsAdd\nSubAppsRemove\nSubAppsList",
  "availability_expectation": "Feature is available only in Isolated Web Apps on desktop platforms.\n\nhttps://chromestatus.com/feature/5146307550248960",
  "adoption_expectation": "Expected to be used initially by a small number of developers inside Isolated Web Apps.",
  "adoption_plan": "Working directly with developers that are planning to rely on the API.",
  "initial_public_proposal_url": "https://github.com/WICG/proposals/issues/282",
  "explainer_links": [
    "https://github.com/WICG/sub-apps"
  ],
  "requires_embedder_support": true,
  "spec_link": "https://wicg.github.io/sub-apps",
  "api_spec": true,
  "automation_spec": false,
  "interop_compat_risks": "Other browsers may choose to implement this API.",
  "all_platforms": null,
  "all_platforms_descr": "This feature is implemented on desktop platforms, although it will only be available to the end users on platforms that support Isolated Web Apps, which is currently only ChromeOS.\n\nAndroid is excluded because installing arbitrary apps is complicated there and needs additional work.",
  "non_oss_deps": null,
  "anticipated_spec_changes": null,
  "security_risks": "Sub-apps share origin identity and all local data stores with their parent app, exposing them to standard same-origin security boundaries.\nPermission grants are shared bidirectionally; granting a permission to a sub-app automatically extends that permission to the parent app.\nThere is a risk of identity spoofing and launcher hijacking, which is mitigated by restricting the API to isolated contexts.\nRegistering custom OS integrations requires explicit user approval to prevent unauthorized protocol handling or file type hijacking.",
  "ergonomics_risks": null,
  "wpt": false,
  "wpt_descr": "JS API interface tests are in third_party/blink/web_tests/external/wpt/subapps.\n\nhttps://wpt.fyi/results/subapps?label=master&label=experimental&aligned&q=subapps\n\nMore complete tests that cover all cases are in chrome/browser/web_applications/sub_apps/sub_apps_service_impl_browsertest.cc",
  "webview_risks": null,
  "devrel_emails": [
    "devrel-chromestatus-all@google.com"
  ],
  "debuggability": "There's no special devTools support for this feature.\nIt is possible to add sub apps, remove and list them via devTools console raw javascript execution. ",
