  "spec_link": "https://w3c.github.io/ServiceWorker/#control-and-use-worker-client",
  "api_spec": false,
  "automation_spec": false,
  "interop_compat_risks": "This is a change to make the Chromium behavior aligned with the specification, there should not be an interoperability issue.\n\nHowever, there is a compatibility issue from the past Chromium.  If a blob URL is used for a SharedWorker script and a controller for the URL is mattered, there is a behavior change because this change makes a controller inherited.\n\nAn enterprise policy was added to allow enterprise customers to preserve the past Chromium behavior.",
  "all_platforms": null,
  "all_platforms_descr": "Since SharedWorker is not supported in Android yet, the feature also does not affect to Android.",
  "non_oss_deps": null,
  "anticipated_spec_changes": null,
  "security_risks": "Since this is adjusting Chromium behavior to specification, there should not be a security risk from a specification perspective.\n\nFrom the implementation perspective, this change simply inherits existing controller.  There should not be any additional security risks with this change.",
  "ergonomics_risks": "n/a",
  "wpt": true,
  "wpt_descr": "https://wpt.fyi/results/service-workers/service-worker/local-url-inherit-controller.https.html\nSame-origin blob URL sharedworker should inherit service worker controller.\nSame-origin blob URL sharedworker should intercept fetch().\n\nThe tests ensure a ServiceWorkerController is inherited.\nDue to crbug.com/40364838, Chromium does not pass the former test.",
  "webview_risks": "Since SharedWorker is not supported on Android yet, there is no risk on Android WebView.",
