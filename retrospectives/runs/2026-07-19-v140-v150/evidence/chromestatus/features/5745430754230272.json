  "all_platforms": false,
  "all_platforms_descr": "This API requires platform specific APIs to communicate the notification to screen readers, and this has not yet been implemented in ChromeOS.",
  "non_oss_deps": null,
  "anticipated_spec_changes": "All open spec issues can be resolved with backwards compatible additions. Recent conversations in the tag review showcase what an backwards-compatible extension might look like and the Mozilla standards position thread go over all of the open issues and how they can be resolved in the future in a backwards-compatible way.\nOpen Issues link: https://github.com/w3c/aria/issues?q=is%3Aissue+is%3Aopen+%5BAriaNotify%5D",
  "security_risks": "",
  "ergonomics_risks": "",
  "wpt": false,
  "wpt_descr": "Web platform tests do not currently have the ability to monitor platform-specific accessibility APIs, [Acacia AAM](https://github.com/Igalia/rfcs/blob/wpt-for-aams-rfc/rfcs/wpt-for-aams.md) will close this gap and allow for testing of such features within WPT",
