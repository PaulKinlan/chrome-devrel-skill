  "explainer_links": [],
  "requires_embedder_support": false,
  "spec_link": "https://drafts.csswg.org/css-backgrounds-4/#background-position-longhands",
  "api_spec": true,
  "automation_spec": false,
  "interop_compat_risks": "This feature doesn't imply any interoperability risk, but the contrary, since Chrome needs to catch up in order to provide the same functionality than Firefox and Safari.\n\nThere is no back-compatibility risk, because the old syntax is still valid if this feature is implemented. ",
  "all_platforms": true,
  "all_platforms_descr": "This feature is implemented in the blink's style module of the web engine, so it's shared among all the platforms.",
