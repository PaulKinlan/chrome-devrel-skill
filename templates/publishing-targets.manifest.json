{
  "schemaVersion": 1,
  "targets": [
    {
      "artifactType": "problem-brief",
      "defaultTarget": "internal",
      "publicTarget": "explainer venue (WICG, CG, etc.)",
      "suggestedReviewRoutes": [
        "DevRel lead",
        "Product owner"
      ]
    },
    {
      "artifactType": "research-plan",
      "defaultTarget": "internal",
      "publicTarget": "methods summary on web.dev or ChromeStatus when evidence is cited",
      "suggestedReviewRoutes": [
        "DevRel lead"
      ]
    },
    {
      "artifactType": "compatibility-matrix",
      "defaultTarget": "public docs",
      "publicTarget": "ChromeStatus, web.dev, developer.chrome.com",
      "suggestedReviewRoutes": [
        "DevRel lead",
        "Engineering lead"
      ]
    },
    {
      "artifactType": "partner-trial-brief",
      "defaultTarget": "internal",
      "publicTarget": "case study only with documented partner consent",
      "suggestedReviewRoutes": [
        "DevRel lead",
        "Partner (consent)"
      ]
    },
    {
      "artifactType": "demo-plan",
      "defaultTarget": "public",
      "publicTarget": "GitHub, web.dev, developer.chrome.com",
      "suggestedReviewRoutes": [
        "DevRel lead"
      ]
    },
    {
      "artifactType": "docs-gap-analysis",
      "defaultTarget": "internal",
      "publicTarget": "tracking issue on public repo",
      "suggestedReviewRoutes": [
        "DevRel lead",
        "Docs team"
      ]
    },
    {
      "artifactType": "launch-brief",
      "defaultTarget": "internal",
      "publicTarget": "blog/docs when published",
      "suggestedReviewRoutes": [
        "DevRel lead",
        "Product owner",
        "Comms"
      ]
    },
    {
      "artifactType": "speaker-deck",
      "defaultTarget": "public",
      "publicTarget": "shared slides repo",
      "suggestedReviewRoutes": [
        "DevRel lead",
        "Comms"
      ]
    },
    {
      "artifactType": "adoption-plan",
      "defaultTarget": "internal",
      "publicTarget": "adoption guide when ready",
      "suggestedReviewRoutes": [
        "DevRel lead"
      ]
    },
    {
      "artifactType": "support-pack",
      "defaultTarget": "public docs",
      "publicTarget": "developer.chrome.com, web.dev",
      "suggestedReviewRoutes": [
        "DevRel lead",
        "Support team"
      ]
    },
    {
      "artifactType": "mdn-reference",
      "defaultTarget": "internal draft",
      "publicTarget": "mdn/content GitHub PR",
      "suggestedReviewRoutes": [
        "DevRel lead",
        "MDN community reviewers"
      ]
    },
    {
      "artifactType": "mdn-bcd-entry",
      "defaultTarget": "internal draft",
      "publicTarget": "mdn/browser-compat-data GitHub PR",
      "suggestedReviewRoutes": [
        "DevRel lead",
        "BCD community reviewers"
      ]
    },
    {
      "artifactType": "youtube-announcement",
      "defaultTarget": "internal draft",
      "publicTarget": "YouTube (public) after review",
      "suggestedReviewRoutes": [
        "DevRel lead",
        "Comms"
      ]
    }
  ],
  "advisoryNote": "suggestedReviewRoutes are advisory starting points. Actual review requirements are team-configured via the owner map (templates/owner-map.template.json). DevRel does not determine whether formal review is required."
}
